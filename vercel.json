{
  "version": 2,
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "site/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/site/index.html" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/(.*)", "dest": "/site/$1" }
  ]
}
